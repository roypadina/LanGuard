<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- LanGuard runs UN-SANDBOXED: it toggles Wi-Fi power via CoreWLAN,
	     reads wired link state, registers a login item, and removes the
	     legacy com.roy.wifitoggle LaunchAgent via launchctl. The sandbox
	     would block all of that. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
